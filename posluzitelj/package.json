		"@types/express-serve-static-core": "^4.19.8",
		"@types/express-session": "^1.18.2",
		"@types/formidable": "^3.4.6",
		"@types/node": "^25.2.3",
		"@types/nodemailer": "^7.0.10",
		"typescript": "^5.9.3"
