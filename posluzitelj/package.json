{
	"name": "zadaca_01",
	"version": "1.0.0",
	"description": "",
	"main": "build/server.js",
	"type": "module",
	"scripts": {
		"pripremi": "npm link --save --package-lock false express  express-session cookie-parser sqlite3 sqlite cors jsonwebtoken nodemailer base32-encoding totp-generator formidable",
		"compile": "tsc --watch false",
		"copy-files": "copyfiles -u 1 src/**/*.html src/**/*.css src/**/*.jpg src/**/*.webp src/**/*.png 'src/**/*.js' build/",
		"clean": "rm -r build/*",
		"server": "node build/server.js podaci/konfiguracija.csv",
		"start": "npm run server",
		"start-spider": "npm run pripremi && npm run server",
		"start-local": "npm run clean; npm run compile && npm run copy-files && npm run server",
		"test": "echo \"Error: no test specified\" && exit 1",
		"zadaca": "node build/server.js podaci/konfiguracija.csv"
	},
	"author": "Luka Kanjir",
	"license": "ISC",
	"dependencies": {
		"base32-encoding": "file:../../../../../usr/lib/node_modules/base32-encoding",
		"better-sqlite3": "file:../../../../../usr/lib/node_modules/better-sqlite3",
		"cookie-parser": "file:../../../../../usr/lib/node_modules/cookie-parser",
		"cors": "file:../../../../../usr/lib/node_modules/cors",
		"express": "file:../../../../../usr/lib/node_modules/express",
		"express-session": "file:../../../../../usr/lib/node_modules/express-session",
		"formidable": "file:../../../../../usr/lib/node_modules/formidable",
		"jsonwebtoken": "file:../../../../../usr/lib/node_modules/jsonwebtoken",
		"nodemailer": "file:../../../../../usr/lib/node_modules/nodemailer",
		"sqlite": "file:../../../../../usr/lib/node_modules/sqlite",
